# Copy to .env (or set in your deploy provider's environment) to enable
# PostHog tracking on the docs site. Without these, the snippet is omitted
# from the build entirely.
#
# Project key from https://us.posthog.com/settings/project — use the
# "Project ID" / public key, NOT the personal API key.
PUBLIC_POSTHOG_KEY=phc_your_project_key_here

# Optional. Defaults to https://us.i.posthog.com if unset. Use
# https://eu.i.posthog.com for the EU region or your own reverse-proxy
# host (see https://posthog.com/docs/advanced/proxy).
# PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
